import logging
import sqlite3
import requests
from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, ContextTypes, filters

TOKEN = "TON_BOT_TOKEN_ICI"

logging.basicConfig(level=logging.INFO)

conn = sqlite3.connect("memory.db", check_same_thread=False)
cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS memory (
user_id TEXT,
message TEXT
)
""")
conn.commit()

def save(user_id, msg):
    cursor.execute("INSERT INTO memory VALUES (?, ?)", (user_id, msg))
    conn.commit()

def scam_detect(text):
    bad_words = ["bitcoin gratuit", "mot de passe", "urgent", "hack", "envoyer argent"]
    return any(w in text.lower() for w in bad_words)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("🤖 Bot Termux actif")

async def message_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = str(update.message.from_user.id)
    text = update.message.text

    save(user_id, text)

    if scam_detect(text):
        await update.message.reply_text("⚠️ Message suspect détecté")

    await update.message.reply_text(f"Tu as écrit : {text}")

app = ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, message_handler))

print("Bot lancé...")
app.run_polling()
